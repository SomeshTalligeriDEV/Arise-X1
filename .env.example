# Arise-X1 Environment Variables
# Copy this file to .env.local and fill in your keys

# AI Analyzer (OpenAI / Groq)
OPENAI_API_KEY=your_openai_key_here

# Maps (Mapbox Public Token)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Firebase (Client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=arise-x1.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=arise-x1
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=arise-x1.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
